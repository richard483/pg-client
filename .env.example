PORT=8090

# Karasu Auth introspection endpoint.
KARASU_INTROSPECT_URL=http://127.0.0.1:8080/oauth/introspect
REQUIRED_AUDIENCE=pg-client-api
REQUIRED_SCOPE=pg-client:execute

# PostgreSQL server-side connection settings.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSLMODE=disable

# Execution safeguards.
QUERY_TIMEOUT_SECONDS=30
MAX_ROWS=1000
MAX_RESPONSE_BYTES=10485760

# run.sh client settings.
# CLIENT_PRIVATE_KEY is the local path to the private key matching the public key
# registered on the Karasu OAuth client.
KARASU_TOKEN_URL=http://127.0.0.1:8080/oauth/token
PG_CLIENT_URL=http://127.0.0.1:8090/execute
CLIENT_ID=app_replace_me
CLIENT_PRIVATE_KEY=./client-private.pem
TOKEN_AUDIENCE=pg-client-api
TOKEN_SCOPE=pg-client:execute
# Set this when Karasu AUTH_BASE_URL differs from KARASU_TOKEN_URL.
# It must match the audience Karasu expects for client assertions.
KARASU_ASSERTION_AUD=http://127.0.0.1:8080/oauth/token
